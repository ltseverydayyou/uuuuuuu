local function svc(n)
	local ok, r = pcall(function()
		return game:GetService(n)
	end)
	if ok then
		return r
	end
	return nil
end

local root
pcall(function()
	root = getfenv(0)
end)
if type(root) ~= "table" then
	root = _G or {}
end

local function get(path)
	local v = root
	for p in tostring(path):gmatch("[^%.]+") do
		if v == nil then
			return nil
		end
		v = v[p]
	end
	return v
end

local function join(t)
	local r = {}
	for i = 1, #t do
		r[i] = tostring(t[i])
	end
	return table.concat(r, ", ")
end

local function names(v)
	if type(v) == "table" then
		return v
	end
	return { v }
end

local function res(v)
	local ns = names(v)
	for i = 1, #ns do
		local nm = ns[i]
		local val = get(nm)
		if val ~= nil then
			return val, nm
		end
	end
	return nil, nil
end

local function need(v)
	local val, nm = res(v)
	assert(val ~= nil, "missing dependency: " .. join(names(v)))
	return val, nm
end

local function short(e)
	local s = tostring(e or "unknown")
	s = s:gsub("\r\n", "\n")
	local out = {}
	for line in s:gmatch("[^\n]+") do
		out[#out + 1] = line
		if #out >= 4 then
			break
		end
	end
	s = table.concat(out, " | ")
	if #s > 420 then
		s = s:sub(1, 420) .. "..."
	end
	return s
end

local function runTimeout(fn, sec)
	local done = false
	local ok, ret
	task.spawn(function()
		ok, ret = pcall(fn)
		done = true
	end)
	local t = os.clock()
	while not done and os.clock() - t < (sec or 8) do
		task.wait(0.03)
	end
	if not done then
		return false, "timed out after " .. tostring(sec or 8) .. "s"
	end
	return ok, ret
end

