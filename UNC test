		assert(ok, err or "setsimulationradius errored")
	end },
	{ n = "isnetworkowner", f = function(fn)
		local p = Instance.new("Part")
		p.Anchored = false
		p.Parent = workspace
		local ok, r = pcall(fn, p)
		p:Destroy()
		assert(ok, r or "isnetworkowner errored")
		assert(type(r) == "boolean", "isnetworkowner must return boolean")
	end },
	{ n = "getscriptfromthread", f = function(fn)
		local co = coroutine.create(function() task.wait() end)
		coroutine.resume(co)
		local ok, r = pcall(fn, co)
		assert(ok, r or "getscriptfromthread errored")
		assert(r == nil or typeof(r) == "Instance", "getscriptfromthread must return Instance or nil")
	end },
	{ n = "getscriptthread", f = function(fn)
		local s = anyScript()
		if not s then
			return "no LocalScript/ModuleScript found; skipped script thread fetch"
		end
		local ok, r = pcall(fn, s)
		assert(ok, r or "getscriptthread errored")
		assert(r == nil or type(r) == "thread", "getscriptthread must return thread or nil")
	end },
	{ n = "cansignalreplicate", f = function(fn)
		local b = Instance.new("BindableEvent")
		local ok, r = pcall(fn, b.Event)
		b:Destroy()
		assert(ok, r or "cansignalreplicate errored")
		assert(type(r) == "boolean", "cansignalreplicate must return boolean")
	end },
	{ n = "getconnection", f = function(fn)
		local b = Instance.new("BindableEvent")
		local cn = b.Event:Connect(function() end)
		local ok, r = pcall(fn, b.Event)
		cn:Disconnect()
		b:Destroy()
		assert(ok, r or "getconnection errored")
		assert(type(r) == "table" or type(r) == "userdata" or r == nil, "getconnection returned unexpected type")
	end },
	{ n = "getsignalarguments", f = function(fn)
		local b = Instance.new("BindableEvent")
		local ok, r = pcall(fn, b.Event)
		b:Destroy()
		assert(ok, r or "getsignalarguments errored")
		assert(type(r) == "table", "getsignalarguments must return table")
	end },
	{ n = "getsignalargumentsinfo", f = function(fn)
		local b = Instance.new("BindableEvent")
		local ok, r = pcall(fn, b.Event)
		b:Destroy()
		assert(ok, r or "getsignalargumentsinfo errored")
		assert(type(r) == "table", "getsignalargumentsinfo must return table")
	end },
	{ n = "getsignalwhitelist", f = function(fn)
		local ok, r = pcall(fn)
		assert(ok, r or "getsignalwhitelist errored")
		assert(type(r) == "table", "getsignalwhitelist must return table")
	end },
	{ n = "Regex.Escape", f = function(fn)
		local r = fn("a.b")
		assert(type(r) == "string", "Regex.Escape must return string")
		assert(r:find(".", 1, true) ~= nil or r:find("\\.", 1, true) ~= nil, "Regex.Escape did not escape dot-like input")
	end },
	{ n = "Regex.new", f = function(fn)
		local ok, r = pcall(fn, "abc")
		assert(ok, r or "Regex.new errored")
		assert(type(r) == "table" or type(r) == "userdata", "Regex.new must return regex object")
	end },
	{ n = "oth.hook", f = function(fn)
		local unhook = res("oth.unhook")
		local function a()
			return "old"
		end
		local ok, r = pcall(fn, a, function()
			return "new"
		end)
		assert(ok, r or "oth.hook errored")
		assert(r ~= nil, "oth.hook must return a hook handle/original callback")
		if type(unhook) == "function" then
			pcall(unhook, a)
			pcall(unhook, r)
		end
	end },
	{ n = "oth.unhook", f = function(fn)
		local hook = res("oth.hook")
		assert(type(hook) == "function", "missing oth.hook dependency")
		local function a()
			return "old"
		end
		local h = hook(a, function()
			return "new"
		end)
		local ok = pcall(fn, a)
		if not ok then ok = pcall(fn, h) end
		assert(ok, "oth.unhook rejected common hook handles")
	end },
	{ n = "oth.get_original_thread", f = function(fn)
		local r = fn()
		assert(r == nil or type(r) == "thread", "oth.get_original_thread returned unexpected type")
	end },
	{ n = "oth.get_root_callback", f = function(fn)
		local r = fn()
		assert(r == nil or type(r) == "function", "oth.get_root_callback returned unexpected type")
	end },
	{ n = "oth.is_hook_thread", f = function(fn)
		assert(type(fn()) == "boolean", "oth.is_hook_thread must return boolean")
	end },
}


local function runOne(d, kind)
	local nmList = d.names or { d.n }
	local fn, used = res(nmList)
	local s = st[kind]
	if fn == nil then
		s.miss += 1
		local msg = d.n .. " -> " .. join(names(nmList))
		if kind == "core" then
			add(ls.miss, msg)
			warn("❌ missing core: " .. msg)
		else
			add(ls.extraMiss, msg)
			print("⏺️ optional missing: " .. msg)
		end
		return
	end
	local label = used == d.n and d.n or (d.n .. " [" .. used .. "]")
	if not d.f then
		s.exist += 1
		local note = d.note or "no safe behavior test"
		if kind == "core" then
			add(ls.exist, label .. " • " .. note)
		else
			add(ls.extraExist, label .. " • " .. note)
		end
		print("⏺️ " .. label .. " • exists; " .. note)
		return
	end
	local ok, ret = runTimeout(function()
		return d.f(fn, used)
	end, d.timeout)
	if ok then
		if type(ret) == "table" and ret._unc_skip then
			s.skip += 1
			local msg = label .. " • " .. tostring(ret._unc_skip)
			if kind == "core" then
				add(ls.skip, msg)
			else
				add(ls.extraSkip, msg)
			end
			print("⏭️ " .. msg)
			return
		end
		s.pass += 1
		if kind == "core" then
			add(ls.pass, label .. (ret and " • " .. tostring(ret) or ""))
		else
			add(ls.extraPass, label .. (ret and " • " .. tostring(ret) or ""))
		end
		line(true, label, ret)
	else
		s.fail += 1
		local msg = label .. " - " .. short(ret)
		if kind == "core" then
			add(ls.fail, msg)
		else
			add(ls.extraFail, msg)
		end
		line(false, label, short(ret))
	end
end

print("\nUNC Environment Check")
print("Core = official sUNC documented functions only")
print("Optional = documented executor extensions; behavior-tested and not counted against UNC score")
print("Aliases are fallback-only and exists-only checks are not counted as passes\n")

for i = 1, #core do
	runOne(core[i], "core")
end

print("\nOptional documented extension checks")
for i = 1, #extra do
	runOne(extra[i], "extra")
end

local delFolder = res("delfolder")
if type(delFolder) == "function" then
	pcall(delFolder, base)
end

local function sort(t)
	table.sort(t, function(a, b)
		return tostring(a) < tostring(b)
	end)
end
for _, t in pairs(ls) do
	sort(t)
end

local total = st.core.pass + st.core.fail + st.core.miss
local rate = total > 0 and math.floor((st.core.pass / total) * 100 + 0.5) or 0
print("\nUNC Summary")
print("✅ Core passes: " .. st.core.pass)
print("⛔ Core behavior fails: " .. st.core.fail)
print("❌ Core missing: " .. st.core.miss)
print("⏺️ Core exists-only: " .. st.core.exist)
print("UNC core score: " .. rate .. "% (" .. st.core.pass .. " / " .. total .. ")")
print("\nOptional documented extensions")
print("✅ Optional passes: " .. st.extra.pass)
print("⛔ Optional behavior fails: " .. st.extra.fail)
print("⏭️ Optional skipped: " .. st.extra.skip)
print("⏺️ Optional exists-only: " .. st.extra.exist)
print("⏺️ Optional missing: " .. st.extra.miss)

if #ls.miss > 0 then
	print("\n❌ Missing core functions:")
	print("  " .. table.concat(ls.miss, ", "))
end

if #ls.extraSkip > 0 then
	print("\n⏭️ Skipped optional functions:")
	print("  " .. table.concat(ls.extraSkip, ", "))
end
if #ls.fail > 0 then
	print("\n⛔ Core behavior failures:")
	print("  " .. table.concat(ls.fail, "\n  "))
end
if #ls.extraFail > 0 then
	print("\n⛔ Optional extension behavior failures:")
	print("  " .. table.concat(ls.extraFail, "\n  "))
end

local verdict
if rate >= 95 and st.core.fail == 0 and st.core.miss == 0 then
	verdict = "Excellent UNC compatibility."
elseif rate >= 85 then
	verdict = "Good UNC compatibility, with a few missing or broken core functions."
elseif rate >= 65 then
	verdict = "Partial UNC compatibility. Several core functions are missing or broken."
else
	verdict = "Poor UNC compatibility. This environment is missing a lot of core UNC behavior."
end
print("\nVerdict: " .. verdict)
