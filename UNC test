local function line(ok, tag, msg)
	if ok then
		print("✅ " .. tag .. (msg and " • " .. tostring(msg) or ""))
	else
		warn("⛔ " .. tag .. (msg and " • " .. tostring(msg) or ""))
	end
end

local function cleanObj(o)
	if o and typeof(o) == "Instance" then
		pcall(function()
			o:Destroy()
		end)
	elseif type(o) == "table" or type(o) == "userdata" then
		pcall(function()
			if o.Remove then
				o:Remove()
			end
		end)
		pcall(function()
			if o.Destroy then
				o:Destroy()
			end
		end)
	end
end

local function notify(t, m, d)
	local sg = svc("StarterGui")
	if sg then
		pcall(function()
			sg:SetCore("SendNotification", {
				Title = tostring(t),
				Text = tostring(m),
				Duration = d or 6,
			})
		end)
	end
	print("[UNC] " .. tostring(t) .. ": " .. tostring(m))
end

local function pushNotif(data, tries)
	local sg = svc("StarterGui")
	if not sg then
		return false, "StarterGui unavailable"
	end
	local last
	for _ = 1, (tries or 10) do
		local ok, err = pcall(function()
			sg:SetCore("SendNotification", data)
		end)
		if ok then
			return true
		end
		last = err
		task.wait(0.2)
	end
	return false, last or "SendNotification failed"
end

local function mkSkip(msg)
	return { _unc_skip = tostring(msg or "skipped") }
end

local rconAskDone = false
local rconAllow = false
local function askRcon()
	if rconAskDone then
		return rconAllow, rconAllow and "approved" or "user chose no"
	end
	local cb = Instance.new("BindableFunction")
	local ans
	cb.OnInvoke = function(v)
		ans = tostring(v or ""):lower()
	end
	local ok, err = pushNotif({
		Title = "UNC rconsole tests",
		Text = "Some executors crash on rconsole. Test rconsole functions?",
		Duration = 15,
		Button1 = "Yes",
		Button2 = "No",
		Callback = cb,
	}, 15)
	if not ok then
		cb:Destroy()
		notify("UNC rconsole tests", "Notification UI failed, so rconsole tests were skipped for safety.", 8)
		rconAskDone = true
		rconAllow = false
		return false, short(err)
	end
	local t = os.clock()
	while ans == nil and os.clock() - t < 15 do
		task.wait(0.05)
	end
	cb:Destroy()
	rconAskDone = true
	rconAllow = ans == "yes"
	if rconAllow then
		notify("UNC rconsole tests", "Approved. Running rconsole checks.", 5)
		return true, "approved"
	end
	notify("UNC rconsole tests", "Skipped rconsole checks.", 5)
	if ans == nil then
		return false, "no response"
	end
	return false, "user chose no"
end

local function needRcon()
	local ok, why = askRcon()
	if ok then
		return true
	end
	return false, why
end

local function mkDraw(kind)
	local new = need({ "Drawing.new" })
	local obj = new(kind or "Square")
	assert(obj ~= nil, "Drawing.new returned nil")
	return obj
end

local function anyScript()
	local plrs = svc("Players")
	local lp = plrs and plrs.LocalPlayer
	local spots = {}
	if lp then
		local ps = lp:FindFirstChildOfClass("PlayerScripts")
		local pg = lp:FindFirstChildOfClass("PlayerGui")
		spots[#spots + 1] = ps
		spots[#spots + 1] = pg
	end
	spots[#spots + 1] = svc("ReplicatedFirst")
	spots[#spots + 1] = svc("ReplicatedStorage")
	for i = 1, #spots do
		local s = spots[i]
		if s then
			local a = s:FindFirstChildWhichIsA("LocalScript", true) or s:FindFirstChildWhichIsA("ModuleScript", true)
			if a then
				return a
			end
		end
	end
	return nil
end

local function prepFolder()
	local isf = res("isfolder")
	local mk = res("makefolder")
	if type(isf) == "function" and type(mk) == "function" and not isf(base) then
		pcall(mk, base)
	end
end

local function rm(path)
	local del = res("delfile")
	if type(del) == "function" then
		pcall(del, path)
	end
end

