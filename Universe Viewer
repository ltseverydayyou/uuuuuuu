local function fetch()
	if fetching then
		return;
	end;
	fetching = true;
	spn(true);
	EMP.Visible = false;
	clr();
	note("Loading places...", 2, "Universe Viewer");
	local tr, ok, pg = 0, false, nil;
	while tr < MAX_RETRIES do
		tr += 1;
		local s, r = pcall(function()
			pg = AS:GetGamePlacesAsync();
		end);
		if s then
			ok = true;
			break;
		else
			task.wait(RETRY_DELAY);
		end;
	end;
	if not ok then
		spn(false);
		fetching = false;
		note("Failed to load places", 4, "Universe Viewer");
		return;
	end;
	local i = 0;
	while true do
		for _, pl in ipairs(pg:GetCurrentPage()) do
			i += 1;
			mk(pl, i);
		end;
		if pg.IsFinished then
			break;
		end;
		pg:AdvanceToNextPageAsync();
	end;
	spn(false);
	apply();
	local curName;
	local curId;
	for _, r in ipairs(rows) do
		if r.cur then
			curName = r.n;
			curId = r.id;
			break;
		end;
	end;
	updateStats(#rows, curName, curId);
	applyTheme();
	fetching = false;
end;
