							return callArgs(hook, self, args)
						end
					end
					return hook(self, ...)
				end)
			elseif type(getrawmetatable) == "function" and type(setreadonly) == "function" and type(getnamecallmethod) == "function" then
				local ok, mt = pcall(getrawmetatable, game)
				if ok and type(mt) == "table" and mt.__namecall then
					local namecall = mt.__namecall
					setreadonly(mt, false)

					local fn = function(self, ...)
						if (not checkcaller or not checkcaller()) and _G.NoFallDMG == true then
							local method = tostring(getnamecallmethod() or ""):lower()
							if method == "fireserver" and tostring(self) == "FD_Event" then
								local args = {...}
								args[1] = 0
								args[2] = 0
								return callArgs(namecall, self, args)
							end
						end
						return namecall(self, ...)
					end

					mt.__namecall = type(newcclosure) == "function" and newcclosure(fn) or fn
					setreadonly(mt, true)
				end
			end
		end
	end

