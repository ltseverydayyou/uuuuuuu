	local fogCons = {}
	local fogLast = nil

	local function wipeFog()
		for i = #fogCons, 1, -1 do
			local c = fogCons[i]
			if c then
				pcall(function()
					c:Disconnect()
				end)
			end
			fogCons[i] = nil
		end
	end

	local function getFogValue()
		local ok, obj = pcall(function()
			local props = Rep:FindFirstChild("CurrentLightingProperties")
			return props and props:FindFirstChild("FogEnd")
		end)
		local has = ok and obj and pcall(function()
			local _ = obj.Value
		end)
		if ok and has and obj.GetPropertyChangedSignal then
			return obj
		end
		return nil
	end

	local function bindFog(sig, fn)
		local c = sig:Connect(fn)
		fogCons[#fogCons + 1] = c
		conns[#conns + 1] = c
		return c
	end

	local function setFogOff(obj)
		obj = obj or getFogValue()
		if not obj then
			return
		end
		if fogLast == nil then
			fogLast = tonumber(obj.Value) or 75
		end
		if obj.Value ~= 9e9 then
			obj.Value = 9e9
		end
	end

	local function watchFog()
		wipeFog()
		if _G.NoFog ~= true then
			return
		end
		local obj = getFogValue()
		if obj then
			setFogOff(obj)
			bindFog(obj:GetPropertyChangedSignal("Value"), function()
				if _G.NoFog == true then
					setFogOff(obj)
				end
			end)
		end
		local props = Rep:FindFirstChild("CurrentLightingProperties")
		if props then
			bindFog(props.ChildAdded, function(ch)
				if _G.NoFog == true and ch.Name == "FogEnd" then
					task.defer(watchFog)
				end
			end)
		end
		bindFog(Rep.ChildAdded, function(ch)
			if _G.NoFog == true and ch.Name == "CurrentLightingProperties" then
				task.defer(watchFog)
			end
		end)
	end

