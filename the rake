	local function scanEsp()
		if _G.FlareGunESP == true then
			local fl = __lt.cm("Workspace", "FindFirstChild", "FlareGunPickUp")
			if fl then
				if not esp.flare or esp.flare.o ~= fl then
					cleanupEsp("flare")
					esp.flare = {
						o = fl,
						d = drawTxt("Flare Gun", Color3.fromRGB(0, 225, 255)),
						h = cham(fl, "FlareGunChams", Color3.fromRGB(255, 0, 0), Color3.fromRGB(170, 170, 170), 0.3),
					}
				end
			else
				cleanupEsp("flare")
			end
		else
			cleanupEsp("flare")
		end

		if _G.RakeChams == true then
			local rk = __lt.cm("Workspace", "FindFirstChild", "Rake")
			if rk then
				if not esp.rake or esp.rake.o ~= rk then
					cleanupEsp("rake")
					esp.rake = {
						o = rk,
						d = drawTxt("Rake", Color3.fromRGB(255, 0, 0)),
						h = cham(rk, "RakeChams", Color3.fromRGB(170, 0, 0), Color3.fromRGB(255, 255, 255), 0.3),
					}
				end
			else
				cleanupEsp("rake")
			end
		else
			cleanupEsp("rake")
		end

		if _G.PlayerESP == true then
			for _, p in pairs(__lt.cm("Players", "GetPlayers")) do
				if p ~= ClonedService("Players").LocalPlayer and p.Character then
					local ch = p.Character
					if not esp.players[p] or esp.players[p].o ~= ch then
						clearOne(esp.players, p)
						esp.players[p] = {
							o = ch,
							d = drawTxt(p.Name, Color3.fromRGB(0, 255, 34)),
							h = cham(ch, "PlayerChams", Color3.fromRGB(0, 11, 170), Color3.fromRGB(170, 170, 170), 0.3),
						}
					end
				end
			end
			for p, it in pairs(esp.players) do
				if not p.Parent or not p.Character or p.Character ~= it.o then
					clearOne(esp.players, p)
				end
			end
		else
			cleanupEsp("players")
		end

		if _G.SupplyDropESP == true then
			local debris = ffc(ClonedService("Workspace"), "Debris")
			local crates = debris and ffc(debris, "SupplyCrates")
			for _, box in pairs(kids(crates)) do
				if box.Name == "Box" and not esp.drops[box] then
					esp.drops[box] = {
						o = box,
						d = drawTxt("Supply Drop", Color3.fromRGB(251, 255, 0)),
						h = nil,
					}
				end
			end
			for box in pairs(esp.drops) do
				if not box.Parent then
					clearOne(esp.drops, box)
				end
			end
		else
			cleanupEsp("drops")
		end

		if _G.ScrapESP == true then
			local filter = ffc(ClonedService("Workspace"), "Filter")
			local root = filter and ffc(filter, "ScrapSpawns")
			for _, v in pairs(desc(root)) do
				if v.Name == "Scrap" and v:IsA("BasePart") and not esp.scraps[v] then
					esp.scraps[v] = {
						o = v,
						d = drawTxt(scrapTxt(v), Color3.fromRGB(77, 35, 1)),
						h = cham(v, "ScrapChams", Color3.fromRGB(77, 35, 1), Color3.fromRGB(170, 170, 170), 0),
					}
				end
			end
			for v in pairs(esp.scraps) do
				if not v.Parent then
					clearOne(esp.scraps, v)
				end
			end
		else
			cleanupEsp("scraps")
		end
	end

	bind(ClonedService("RunService").Heartbeat, function(dt)
		if AllowRunService ~= true then
			cleanupEsp()
			return
		end

		scanT += dt
		updT += dt

		if scanT >= (tonumber(st.espScan) or 0.75) then
			scanT = 0
			scanEsp()
		end

		if updT < 0.033 then
			return
		end
		updT = 0

		if _G.LocationESP == true then
			local root = getLocFolder()
			local alive = {}
			if root then
				for _, obj in pairs(kids(root)) do
					local pos = locPos(obj)
					if pos then
						alive[obj] = true
						local name = locName(obj)
						local d = esp.locs[obj]
						if not d then
							d = drawTxt("[LOCATION] "..name, Color3.fromRGB(255, 136, 0))
							esp.locs[obj] = d
						end
						show(d, pos, "[LOCATION] "..name)
					end
				end
			end
			for obj, d in pairs(esp.locs) do
				if not alive[obj] or not obj.Parent then
					safeDrawRemove(d)
					esp.locs[obj] = nil
				end
			end
		else
			cleanupEsp("locs")
		end

		if esp.flare then
			local fl = esp.flare.o
			local part = fl and (ffc(fl, "FlareGun") or fl)
			show(esp.flare.d, _G.FlareGunESP and posOf(part), "Flare Gun")
		end

		if esp.rake then
			local rk = esp.rake.o
			local mons = rk and ffc(rk, "Monster")
			local hp = valOf(mons and ffc(mons, "Health"), nil)
			if hp == nil and rk and rk:FindFirstChildOfClass("Humanoid") then
				hp = rk:FindFirstChildOfClass("Humanoid").Health
			end
			show(esp.rake.d, _G.RakeChams and posOf(ffc(rk, "Head") or rk), "Rake, Health : "..tostring(hp or "?"))
		end

		for p, it in pairs(esp.players) do
			local ch = it.o
			local head = ch and ffc(ch, "Head")
			local txt = p.Name
			if _G.PlayerESPShowDistance == true then
