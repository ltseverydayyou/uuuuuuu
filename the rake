	local function wipeFovConns()
		for i = #fovConns, 1, -1 do
			local c = fovConns[i]
			if c then
				pcall(function()
					c:Disconnect()
				end)
			end
			fovConns[i] = nil
		end
	end

	local function applyFov(force)
		if not AllowRunService or st.fovOn ~= true then
			return
		end
		local cam = Ws.CurrentCamera or workspace.CurrentCamera
		if not cam then
			return
		end
		local num = math.clamp(tonumber(st.fov) or 70, 1, 120)
		if force or lastCam ~= cam or lastFov ~= num or cam.FieldOfView ~= num then
			lastCam = cam
			lastFov = num
			pcall(function()
				cam.FieldOfView = num
			end)
		end
	end

	function bindFovCam(cam)
		wipeFovConns()
		if not cam then
			return
		end
		lastCam = nil
		local ok, c = pcall(function()
			return cam:GetPropertyChangedSignal("FieldOfView"):Connect(function()
				if AllowRunService == true and st.fovOn == true then
					task.defer(function()
						applyFov(true)
					end)
				end
			end)
		end)
		if ok and c then
			fovConns[#fovConns + 1] = c
			conns[#conns + 1] = c
		end
		applyFov(true)
	end

	local function applySpeed(force)
		if not AllowRunService or st.spdOn ~= true then
			return
		end
		local hum = getHum()
		if not hum or not hum.Parent then
			return
		end
		local spd = math.clamp(tonumber(st.spd) or 16, 0, 30)
		if force or hum.WalkSpeed ~= spd then
			pcall(function()
				hum.WalkSpeed = spd
			end)
		end
	end

	local function onChar(ch)
		wipeCharConns()
		curChar = ch
		curHum = nil
		if not ch then
			return
		end
		task.spawn(function()
			local hum = ch:FindFirstChildOfClass("Humanoid") or ch:WaitForChild("Humanoid", 10)
			if hum then
				curHum = hum
				applySpeed(true)
				bindChar(hum:GetPropertyChangedSignal("WalkSpeed"), function()
					applySpeed(true)
				end)
			end
		end)
	end

	local lp = Plrs.LocalPlayer
	if lp then
		if lp.Character then
			task.defer(onChar, lp.Character)
		end
		bind(lp.CharacterAdded, onChar)
	end

