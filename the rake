			end
			show(it.d, _G.PlayerESP and posOf(head or ch), txt)
		end

		for box, it in pairs(esp.drops) do
			show(it.d, _G.SupplyDropESP and posOf(ffc(box, "HitBox") or box), "Supply Drop")
		end

		for v, it in pairs(esp.scraps) do
			show(it.d, _G.ScrapESP and posOf(v), scrapTxt(v))
		end
	end)

