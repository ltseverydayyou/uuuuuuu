function st.clean()
	st.dead = true
	if type(st.opt) == "table" then
		for k in st.opt do
			st.opt[k] = false
		end
	end
	for i = 1, #st.cn do
		local c = st.cn[i]
		if c then
			pcall(function()
				c:Disconnect()
			end)
			st.cn[i] = nil
		end
	end
	for c in st.dis do
		pcall(function()
			c:Enable()
		end)
		st.dis[c] = nil
	end
end

