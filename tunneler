local function gp(root, ...)
	local obj = root
	for i = 1, select("#", ...) do
		if not obj then
			return nil
		end
		obj = obj:FindFirstChild(select(i, ...))
	end
	return obj
end

local function val(obj, def)
	if not obj then
		return def
	end
	local ok, v = pcall(function()
		return obj.Value
	end)
	if ok then
		return v
	end
	return def
end

local function setv(obj, v)
	if not obj then
		return false
	end
	local ok = pcall(function()
		obj.Value = v
	end)
	return ok
end

local function boolv(root, name, v)
	local obj = root and root:FindFirstChild(name)
	if obj then
		setv(obj, v)
	end
	return obj
end

local function num(v, def)
	v = tonumber(v)
	if v == nil then
		return def
	end
	return v
end

