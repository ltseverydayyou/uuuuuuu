local function watch(obj, e)
	if not obj or not e then
		return
	end
	bind(obj:GetPropertyChangedSignal("Value"), function()
		if st.dead then
			return
		end
		pcall(function()
			e:Set(obj.Value)
		end)
	end)
end

local function uiToggle(tab, title, obj, flag)
	local o = pg(obj)
	if o then
		local e = tog(tab, title, flag, val(o, false), function(v)
			setv(o, v)
		end)
		watch(o, e)
		return e
	end
end

