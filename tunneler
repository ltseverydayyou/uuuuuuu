local function tog(tab, name, flag, cur, cb)
	local e = tab:CreateToggle({
		Name = name,
		CurrentValue = cur == true,
		Flag = flag,
		Callback = function(v)
			st.opt[flag] = v == true
			if cb then
				pcall(cb, v == true)
			end
		end
	})
	elems[flag] = e
	st.opt[flag] = cur == true
	return e
end

local function sl(tab, name, flag, range, inc, cur, suf, cb)
	local e = tab:CreateSlider({
		Name = name,
		Range = range,
		Increment = inc,
		Suffix = suf or "",
		CurrentValue = cur,
		Flag = flag,
		Callback = function(v)
			st[flag] = v
			if cb then
				pcall(cb, v)
			end
		end
	})
	st[flag] = cur
	return e
end

