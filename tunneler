local function setVideo(n, v)
	setv(gp(ui, "GameSettings", "Video", n), v)
end

local function applyPerf()
	if st.opt.noBloom then
		setVideo("Bloom", false)
		local b = light:FindFirstChildOfClass("BloomEffect") or light:FindFirstChild("Bloom")
		if b then
			pcall(function()
				b.Intensity = 0
			end)
		end
	end
	if st.opt.noCC then
		setVideo("ColorCorrection", false)
		for _, v in light:GetChildren() do
			if v:IsA("ColorCorrectionEffect") then
				v.Enabled = false
			end
		end
	end
	if st.opt.noShake then
		setVideo("CameraShakeEnabled", false)
	end
	if st.opt.noPhys then
		setVideo("PhysicalParticles", false)
	end
	if st.opt.noWavy then
		setVideo("WavyBeamsEnabled", false)
	end
	if st.opt.noShadow then
		setVideo("Shadows", false)
		light.GlobalShadows = false
	end
	if st.opt.noDof then
		for _, v in light:GetChildren() do
			if v:IsA("DepthOfFieldEffect") then
				v.Enabled = false
				v.FarIntensity = 0
				v.NearIntensity = 0
			end
		end
	end
	if st.opt.noTv then
		for _, v in workspace:QueryDescendants("VideoFrame") do
			v.Playing = false
			v.Volume = 0
		end
	end
	if st.opt.noGlares then
		for _, v in workspace:QueryDescendants("Instance") do
			if v.Name == "ClientLightGlare" and v.Parent and v.Parent:IsA("BillboardGui") then
				v.Parent.Enabled = false
			end
		end
	end
end

local function setPortalCollide(v)
	local ps = workspace:FindFirstChild("Portals")
	if not ps then
		return
	end
	for _, p in ps:GetChildren() do
		local w = p:FindFirstChild("WorldColliders")
		if w then
			for _, c in w:GetChildren() do
				if c:IsA("BasePart") then
					c.CanCollide = v
					c.CanTouch = v
				end
			end
		end
	end
end

local function scanBypasses()
	if st.opt.emancBypass then
		local lvl = workspace:FindFirstChild("Level")
		if lvl then
			for _, v in lvl:QueryDescendants("Instance") do
				if string.find(v.Name, "EmancipationGrill") then
					local d = v:FindFirstChild("Disabled")
					if d then
						setv(d, true)
					end
				end
			end
		end
	end
	if st.opt.noPortalCollide then
		setPortalCollide(false)
	end
end

local function touchCon(on)
	if not cap.conn then
		return
	end
	local r = root()
	if not r then
		return
	end
	if on then
		local now = os.clock()
		if now < st.nextCon then
			return
		end
		st.nextCon = now + 1
		local ok, cons = pcall(getconnections, r.Touched)
		if ok and type(cons) == "table" then
			for _, c in cons do
				if c and not st.dis[c] then
					st.dis[c] = true
					pcall(function()
						c:Disable()
					end)
				end
			end
		end
	else
		for c in st.dis do
			pcall(function()
				c:Enable()
			end)
			st.dis[c] = nil
		end
	end
end

local function loop(dt)
	if st.dead then
		return
	end
	local c = char()
	local h = hum()
	local r = root()
	st.char = c
	st.hum = h
	st.root = r
	if st.opt.loopGod then
		setv(pg("god"), true)
		if h and h.Health > 0 then
			pcall(function()
				h.MaxHealth = math.max(h.MaxHealth, 100)
				if h.Health < h.MaxHealth then
					h.Health = h.MaxHealth
				end
			end)
		end
	end
	if st.opt.pauseBypass then
		setv(pg("pauseMenuOpen"), false)
	end
	if st.opt.forceMove and c then
		boolv(c, "canMove", true)
		if h then
			h.PlatformStand = false
			h.Sit = false
		end
		if r then
			r.Anchored = false
		end
	end
	if st.opt.noRag and c then
		boolv(c, "useDeathRagdoll", false)
		local dr = c:FindFirstChild("deathRagdoll")
		if dr then
			pcall(function()
				dr.Value = nil
			end)
		end
	end
	if st.opt.jumpBypass and c then
		boolv(c, "insideJumpDisableZone", false)
	end
	if st.opt.emancBypass and c then
		boolv(c, "insideEmancipationGrill", false)
	end
	if st.opt.noDrown and c then
		boolv(c, "isUnderwater", false)
		local dg = ui:FindFirstChild("DrowningIndicator")
		local vg = dg and dg:FindFirstChild("Vignette")
		if vg then
			vg.ImageTransparency = 1
		end
		local wb = light:FindFirstChild("WaterBlur")
		if wb then
			wb.Size = 0
		end
	end
	if st.opt.noSwim and c then
		boolv(c, "isSwimming", false)
	end
	if st.opt.loopGun then
		setv(pg("hasPortalGun"), true)
		setv(pg("PortalLevel"), st.gunLevel or 2)
	end
	if st.opt.loopMat then
		setv(pg("portalsIgnoreMaterial"), true)
	end
	if st.opt.shootReady and c then
		boolv(c, "shooting", false)
		boolv(c, "vrRightHandClipping", false)
	end
	if pg("wantedColor") then
		if st.opt.rgbEnabled then
			local hue = (os.clock() * (st.rgbSpeed or 0.15)) % 1
			setv(pg("wantedColor"), Color3.fromHSV(hue, 1, 1))
		elseif st.opt.gunLoop then
			setv(pg("wantedColor"), st.gunColor)
		end
	end
	if st.opt.antiVoid and r then
		local fh = workspace.FallenPartsDestroyHeight or -500
		local av = r.AssemblyLinearVelocity
		if av.Y < -(st.fallLimit or 20) then
			r.AssemblyLinearVelocity = Vector3.new(av.X, -(st.fallLimit or 20), av.Z)
		end
		if r.Position.Y < fh + 35 then
			r.CFrame = r.CFrame + Vector3.new(0, st.voidRaise or 15, 0)
			r.AssemblyLinearVelocity = Vector3.new(av.X, math.abs(st.fallLimit or 20), av.Z)
		end
	end
	touchCon(st.opt.disableTouch)
	local now = os.clock()
	if now >= st.nextScan then
		st.nextScan = now + 1
		scanBypasses()
	end
	if now >= st.nextPerf then
		st.nextPerf = now + 2
		applyPerf()
	end
end

